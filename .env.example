# Capstone — environment variables
# --------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# NEVER commit your real keys.

# ── LLM backend ─────────────────────────────────────────────────────
# Selects which LLM provider to use.
#   - "ollama" : local inference (default when no Groq key is present)
#   - "groq"   : hosted free-tier inference (default when GROQ_API_KEY is set)
# CAPSTONE_LLM_BACKEND=groq

# Override the specific model. Leave unset to use the backend's default.
# Examples:
#   - Groq:    llama-3.3-70b-versatile, gemma2-9b-it
#   - Ollama:  qwen2.5:7b, phi4:14b, gemma3:27b
# CAPSTONE_LLM_MODEL=llama-3.3-70b-versatile

# Groq API key — get one free at https://console.groq.com/keys
# GROQ_API_KEY=gsk_yourkeyhere

# Skip the first-run setup wizard (useful in Docker / CI)
# CAPSTONE_SKIP_FIRSTRUN=1

# ── Cold-start bootstrap scrapes (deploy/boot.py) ───────────────────
# On a hosted deploy there is no CLI, so boot.py seeds the database once.
# Catalog + all 35 majors + the public time schedule are scraped by default.
#
# RateMyProfessor ratings are OPT-IN (their ToS prohibits automated access).
# Set this to populate the UI's instructor-rating badges without a CLI:
# CAPSTONE_SCRAPE_PROFESSORS=1
#
# Skip the public time-schedule scrape (instructor badges need it):
# CAPSTONE_SCRAPE_TIMESCHEDULE=0

# ── Database ────────────────────────────────────────────────────────
# Override the SQLite catalog path (Docker uses /home/capstone/data/capstone.db)
# CAPSTONE_DB=./capstone.db

# ── Hosted database (Turso / libSQL) ────────────────────────────────
# Leave BOTH unset for local development — the app uses a local SQLite
# file and the test suite never touches the cloud. Set BOTH to point the
# deployed app at a managed Turso database (it then runs as an embedded
# replica: a local file kept in sync with the cloud primary).
#
#   1. Install the CLI:   curl -sSfL https://get.tur.so/install.sh | bash
#   2. turso auth signup
#   3. turso db create capstone-uwb
#   4. turso db show capstone-uwb --url          # -> CAPSTONE_TURSO_URL
#   5. turso db tokens create capstone-uwb       # -> CAPSTONE_TURSO_AUTH_TOKEN
#
# CAPSTONE_TURSO_URL=libsql://capstone-uwb-yourname.turso.io
# CAPSTONE_TURSO_AUTH_TOKEN=eyJhbGciOi...
